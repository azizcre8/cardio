# Public site / auth
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-side Supabase access
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ACCESS_TOKEN=sbp_...

# Generation / validation
OPENAI_API_KEY=sk-...

# Billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STUDENT_PRICE_ID=price_...
STRIPE_BOARDS_PRICE_ID=price_...

# Feature flags: set to "false" to disable specific pipeline checks
ENABLE_TEXT_QUALITY_CHECK=true
ENABLE_EVIDENCE_GATING=true
ENABLE_HYBRID_RETRIEVAL=true
ENABLE_CONFUSION_DISTRACTORS=true
ENABLE_STRUCTURAL_CHUNKING=true
ENABLE_FUZZY_EVIDENCE_MATCH=true
ENABLE_NEGATIVE_RAG=true
ENABLE_L3_GROUNDING_GUARD=true
ENABLE_DYNAMIC_MODEL_ROUTING=true
ENABLE_STRICT_QUESTION_VALIDATION=true
ENABLE_STRUCTURED_CONFUSION_MAP=true
ENABLE_DISTRACTOR_CANDIDATE_POOL=true
ENABLE_SLOT_BASED_GENERATION=true
